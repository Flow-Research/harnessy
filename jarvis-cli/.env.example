# Jarvis Environment Variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key for AI suggestions
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Path to context files (default: ./context)
# JARVIS_CONTEXT_PATH=./context

# Optional: Path to data storage (default: ~/.jarvis)
# JARVIS_DATA_PATH=~/.jarvis

# Optional: Twitter/X API bearer token for tweet fetching
# If not set, Jarvis uses the free fxtwitter API as a fallback
# JARVIS_TWITTER_TOKEN=your_twitter_bearer_token
