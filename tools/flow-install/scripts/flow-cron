#!/usr/bin/env python3
"""
flow-cron — Standardized scheduling for Harnessy skills.

Reads `schedule:` entries from skill manifests and manages scheduled jobs.
On macOS, uses launchd (survives sleep). On Linux, uses crontab.

Usage:
    flow-cron list                              Show all declared schedules
    flow-cron enable  <skill> <schedule-name>   Activate a schedule
    flow-cron disable <skill> <schedule-name>   Deactivate a schedule
    flow-cron run     <skill> <schedule-name>   Trigger immediately
    flow-cron install                           Install schedules (launchd or crontab)
    flow-cron uninstall                         Remove all flow-cron schedules
    flow-cron status                            Show active schedules
"""

from __future__ import annotations

import argparse
import json
import os
import plistlib
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


# ── Paths ──────────────────────────────────────────────────────────────────

SKILLS_ROOT = Path(os.environ.get("AGENTS_SKILLS_ROOT", Path.home() / ".agents" / "skills"))
CRON_STATE_DIR = Path.home() / ".agents" / "cron"
SCHEDULES_PATH = CRON_STATE_DIR / "schedules.json"
LOG_PATH = CRON_STATE_DIR / "flow-cron.log"
CRON_TAG = "# flow-harness"

LAUNCHD_PREFIX = "com.flow-harness"
LAUNCHD_DIR = Path.home() / "Library" / "LaunchAgents"

IS_MACOS = sys.platform == "darwin"


# ── Manifest scanning ─────────────────────────────────────────────────────

def find_all_schedules() -> list[dict[str, Any]]:
    """Scan skill manifests AND project-level .jarvis/cron.yaml for schedules.

    Two sources:
    1. Skill manifests (~/.agents/skills/*/manifest.yaml) — portable, skill-intrinsic
    2. Project cron file (.jarvis/cron.yaml) — project-specific schedules
    """
    try:
        import yaml
    except ImportError:
        print("Error: PyYAML not installed. Run: pip install pyyaml", file=sys.stderr)
        sys.exit(1)

    schedules = []

    # Source 1: Skill manifests
    if SKILLS_ROOT.exists():
        for manifest_path in sorted(SKILLS_ROOT.rglob("manifest.yaml")):
            try:
                with open(manifest_path) as f:
                    manifest = yaml.safe_load(f)
            except Exception:
                continue

            if not manifest or "schedule" not in manifest:
                continue

            skill_name = manifest.get("name", manifest_path.parent.name)

            for entry in manifest["schedule"]:
                schedules.append({
                    "skill": skill_name,
                    "name": entry.get("name", "default"),
                    "cron": entry.get("cron", ""),
                    "command": entry.get("command", ""),
                    "type": entry.get("type", "prompt"),
                    "description": entry.get("description", ""),
                    "enabled": entry.get("enabled", False),
                    "attempts": entry.get("attempts", ""),
                    "source": f"skill:{skill_name}",
                    "source_path": str(manifest_path),
                })

    # Source 2: Project-level .jarvis/cron.yaml
    project_cron = find_project_cron()
    if project_cron and project_cron.exists():
        try:
            with open(project_cron) as f:
                data = yaml.safe_load(f)
        except Exception:
            data = None

        if data and "schedules" in data:
            for entry in data["schedules"]:
                schedules.append({
                    "skill": entry.get("skill", "project"),
                    "name": entry.get("name", "default"),
                    "cron": entry.get("cron", ""),
                    "command": entry.get("command", ""),
                    "type": entry.get("type", "prompt"),
                    "description": entry.get("description", ""),
                    "enabled": entry.get("enabled", False),
                    "attempts": entry.get("attempts", ""),
                    "source": "project",
                    "source_path": str(project_cron),
                })

    return schedules


def find_project_cron() -> Path | None:
    """Find .jarvis/cron.yaml in the current project."""
    project_dir = Path(detect_project_dir())
    cron_path = project_dir / ".jarvis" / "cron.yaml"
    if cron_path.exists():
        return cron_path
    return None


# ── State management ──────────────────────────────────────────────────────

def load_state() -> dict[str, Any]:
    """Load the schedules state file."""
    if SCHEDULES_PATH.exists():
        try:
            return json.loads(SCHEDULES_PATH.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return {"schedules": {}, "last_updated": None}


def save_state(state: dict[str, Any]) -> None:
    """Save the schedules state file."""
    CRON_STATE_DIR.mkdir(parents=True, exist_ok=True)
    state["last_updated"] = datetime.now(timezone.utc).isoformat()
    SCHEDULES_PATH.write_text(json.dumps(state, indent=2))


def get_schedule_key(skill: str, name: str) -> str:
    return f"{skill}/{name}"


def is_enabled(state: dict, skill: str, name: str) -> bool:
    """Check if a schedule is enabled (state overrides manifest default)."""
    key = get_schedule_key(skill, name)
    return state.get("schedules", {}).get(key, {}).get("enabled", False)


# ── Shared helpers ───────────────────────────────────────────────────────

def detect_project_dir() -> str:
    """Detect the project directory (git root or cwd)."""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        )
        return result.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return os.getcwd()


def collect_path_dirs() -> str:
    """Capture the current PATH for use in scheduled jobs."""
    return os.environ.get("PATH", "/usr/local/bin:/usr/bin:/bin")


def build_shell_command(schedule: dict, project_dir: str) -> str:
    """Build the actual shell command string for a schedule.

    All commands are wrapped through flow-cron-exec for automatic retry,
    structured logging, and failure notifications.
    """
    command = schedule["command"]
    entry_type = schedule.get("type", "prompt")
    skill = schedule["skill"]
    name = schedule["name"]
    task_id = f"{skill}/{name}"

    exec_script = os.path.join(project_dir, "tools", "flow-install", "scripts", "flow-cron-exec")
    attempts = schedule.get("attempts", "")
    attempts_flag = f' --attempts {attempts}' if attempts else ""

    if entry_type == "shell":
        inner_cmd = command
    else:
        inner_cmd = (
            f'claude -p --dangerously-skip-permissions '
            f'"{command}"'
        )

    return (
        f'cd "{project_dir}" && '
        f'python3 "{exec_script}" --task "{task_id}"{attempts_flag} -- '
        f'/bin/zsh -c \'{inner_cmd}\''
    )


# ── launchd (macOS) ─────────────────────────────────────────────────────

def launchd_label(skill: str, name: str) -> str:
    """Generate a launchd job label."""
    return f"{LAUNCHD_PREFIX}.{skill}.{name}"


def launchd_plist_path(skill: str, name: str) -> Path:
    """Path to the plist file for a schedule."""
    return LAUNCHD_DIR / f"{launchd_label(skill, name)}.plist"


def parse_cron_to_calendar(cron_expr: str) -> list[dict[str, int]]:
    """Convert a cron expression to launchd StartCalendarInterval dicts.

    Supports: minute, hour, day-of-month, month, day-of-week.
    Supports simple values, wildcards (*), and step values (*/N) for hours.
    """
    parts = cron_expr.strip().split()
    if len(parts) != 5:
        raise ValueError(f"Invalid cron expression (expected 5 fields): {cron_expr}")

    minute, hour, dom, month, dow = parts

    def parse_field(field: str, key: str) -> list[int | None]:
        """Return list of values for a field. None means wildcard."""
        if field == "*":
            return [None]
        if field.startswith("*/"):
            step = int(field[2:])
            ranges = {
                "Minute": 60, "Hour": 24, "Day": 31,
                "Month": 12, "Weekday": 7,
            }
            max_val = ranges.get(key, 60)
            return list(range(0, max_val, step))
        if "-" in field:
            start, end = field.split("-", 1)
            return list(range(int(start), int(end) + 1))
        if "," in field:
            return [int(v) for v in field.split(",")]
        return [int(field)]

    minutes = parse_field(minute, "Minute")
    hours = parse_field(hour, "Hour")
    doms = parse_field(dom, "Day")
    months = parse_field(month, "Month")
    dows = parse_field(dow, "Weekday")

    # Build calendar interval dicts — one per combination of non-wildcard values.
    # launchd uses 0=Sunday for Weekday.
    intervals = []
    for m in minutes:
        for h in hours:
            for d in doms:
                for mo in months:
                    for w in dows:
                        entry: dict[str, int] = {}
                        if m is not None:
                            entry["Minute"] = m
                        if h is not None:
                            entry["Hour"] = h
                        if d is not None:
                            entry["Day"] = d
                        if mo is not None:
                            entry["Month"] = mo
                        if w is not None:
                            entry["Weekday"] = w
                        if entry:
                            intervals.append(entry)

    return intervals if intervals else [{}]


def build_launchd_plist(schedule: dict, project_dir: str) -> dict:
    """Build a launchd plist dict for a schedule."""
    label = launchd_label(schedule["skill"], schedule["name"])
    shell_cmd = build_shell_command(schedule, project_dir)
    path = collect_path_dirs()
    calendar = parse_cron_to_calendar(schedule["cron"])

    plist: dict[str, Any] = {
        "Label": label,
        "ProgramArguments": ["/bin/zsh", "-c", shell_cmd],
        "StartCalendarInterval": calendar if len(calendar) > 1 else calendar[0],
        "EnvironmentVariables": {
            "PATH": path,
            "HOME": str(Path.home()),
            "LANG": "en_US.UTF-8",
        },
        "WorkingDirectory": project_dir,
        "StandardOutPath": str(LOG_PATH),
        "StandardErrorPath": str(LOG_PATH),
        "RunAtLoad": False,
    }

    return plist


def install_launchd(enabled: list[dict], project_dir: str) -> None:
    """Write plist files and load them into launchd."""
    LAUNCHD_DIR.mkdir(parents=True, exist_ok=True)
    CRON_STATE_DIR.mkdir(parents=True, exist_ok=True)

    for s in enabled:
        label = launchd_label(s["skill"], s["name"])
        plist_path = launchd_plist_path(s["skill"], s["name"])
        plist = build_launchd_plist(s, project_dir)

        # Unload first if already loaded (idempotent)
        subprocess.run(
            ["launchctl", "bootout", f"gui/{os.getuid()}", str(plist_path)],
            capture_output=True,
        )

        # Write plist
        with open(plist_path, "wb") as f:
            plistlib.dump(plist, f)

        # Clear any persistent "disabled" flag for this label. macOS auto-disables
        # labels after repeated bootstrap/launch failures; once disabled, bootstrap
        # returns a generic EIO ("Bootstrap failed: 5: Input/output error") with no
        # diagnostic. `enable` is idempotent and a no-op on never-disabled labels.
        subprocess.run(
            ["launchctl", "enable", f"gui/{os.getuid()}/{label}"],
            capture_output=True,
        )

        # Load
        result = subprocess.run(
            ["launchctl", "bootstrap", f"gui/{os.getuid()}", str(plist_path)],
            capture_output=True, text=True,
        )
        if result.returncode != 0 and "already bootstrapped" not in result.stderr.lower():
            print(f"  ⚠ Failed to load {label}: {result.stderr.strip()}", file=sys.stderr)
        else:
            print(f"  {s['skill']}/{s['name']}: {s['cron']} — {s['description']}")


def uninstall_launchd() -> None:
    """Unload and remove all flow-harness launchd jobs."""
    if not LAUNCHD_DIR.exists():
        return

    count = 0
    for plist_path in sorted(LAUNCHD_DIR.glob(f"{LAUNCHD_PREFIX}.*.plist")):
        subprocess.run(
            ["launchctl", "bootout", f"gui/{os.getuid()}", str(plist_path)],
            capture_output=True,
        )
        plist_path.unlink()
        count += 1

    print(f"Removed {count} flow-harness launchd job(s).")


def status_launchd() -> None:
    """Show active flow-harness launchd jobs."""
    result = subprocess.run(
        ["launchctl", "list"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print("Failed to query launchd.", file=sys.stderr)
        return

    entries = []
    for line in result.stdout.splitlines():
        if LAUNCHD_PREFIX in line:
            entries.append(line)

    if not entries:
        print("No flow-harness jobs in launchd.")
        return

    print(f"Active launchd jobs ({len(entries)}):\n")
    print(f"  {'PID':<8} {'Runs':<6} {'Last':<10} Label")
    print(f"  {'─'*6}  {'─'*4}  {'─'*8}  {'─'*40}")
    for line in entries:
        parts = line.split("\t")
        if len(parts) < 3:
            continue
        pid = parts[0].strip() or "-"
        label = parts[2].strip()
        short_label = label.replace(f"{LAUNCHD_PREFIX}.", "")

        health = _launchctl_health(label)
        runs = health.get("runs", 0)
        last_exit = health.get("last_exit")
        if last_exit is None:
            last_marker = "—" if runs == 0 else "?"
        elif last_exit == 0:
            last_marker = "ok"
        else:
            last_marker = f"EXIT {last_exit}"

        print(f"  {pid:<8} {runs:<6} {last_marker:<10} {short_label}")

    # Show last execution results from structured log
    exec_log = CRON_STATE_DIR / "exec.log.ndjson"
    if exec_log.exists():
        last_results = _parse_last_results(exec_log)
        if last_results:
            print(f"\nLast execution results:\n")
            print(f"  {'Task':<35} {'Status':<12} {'Attempts':<10} {'When'}")
            print(f"  {'─'*33}  {'─'*10}  {'─'*8}  {'─'*20}")
            for task, info in sorted(last_results.items()):
                status = info["event"]
                attempts = info["attempt"]
                when = info["ts"][:16].replace("T", " ")
                # Color-code status
                if status == "success":
                    marker = "ok"
                elif status == "permanent_failure":
                    marker = "PERM FAIL"
                elif status == "failure":
                    marker = "FAILED"
                else:
                    marker = status
                print(f"  {task:<35} {marker:<12} {attempts:<10} {when}")
    else:
        print("\nNo execution history yet (exec.log.ndjson not found).")

    # Also show plist files for reference
    if LAUNCHD_DIR.exists():
        plists = sorted(LAUNCHD_DIR.glob(f"{LAUNCHD_PREFIX}.*.plist"))
        if plists:
            print(f"\nPlist files ({len(plists)}):")
            for p in plists:
                print(f"  {p}")


def _parse_last_results(exec_log: Path) -> dict[str, dict]:
    """Parse exec.log.ndjson and return the last terminal event per task."""
    last = {}
    terminal_events = {"success", "failure", "permanent_failure"}
    try:
        for line in exec_log.read_text().splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
            except json.JSONDecodeError:
                continue
            if entry.get("event") in terminal_events:
                last[entry["task"]] = entry
    except OSError:
        pass
    return last


def _launchctl_health(label: str) -> dict:
    """Query launchd for a label's run count and last exit code.

    The 'Exit' column in `launchctl list` reads 0 for never-run jobs, which gives
    false reassurance — the silent-failure case (e.g. broken cwd causing the
    wrapper to never start) can leave that column at 0 while runs accumulate
    with non-zero exits. `launchctl print` distinguishes the two via 'runs = N'
    and 'last exit code = (never exited)|N'.
    """
    result = subprocess.run(
        ["launchctl", "print", f"gui/{os.getuid()}/{label}"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return {}
    info: dict = {"runs": 0, "last_exit": None}
    for line in result.stdout.splitlines():
        s = line.strip()
        if s.startswith("runs = "):
            try:
                info["runs"] = int(s.split("=", 1)[1].strip())
            except ValueError:
                pass
        elif s.startswith("last exit code = "):
            val = s.split("=", 1)[1].strip()
            if val != "(never exited)":
                try:
                    info["last_exit"] = int(val)
                except ValueError:
                    pass
    return info


# ── Crontab (Linux fallback) ────────────────────────────────────────────

def get_current_crontab() -> str:
    try:
        result = subprocess.run(["crontab", "-l"], capture_output=True, text=True)
        return result.stdout if result.returncode == 0 else ""
    except FileNotFoundError:
        return ""


def write_crontab(content: str) -> None:
    proc = subprocess.run(["crontab", "-"], input=content, capture_output=True, text=True)
    if proc.returncode != 0:
        print(f"Error writing crontab: {proc.stderr}", file=sys.stderr)
        sys.exit(1)


def remove_flow_path(crontab: str) -> str:
    lines = crontab.splitlines()
    cleaned = []
    skip_next = False
    for line in lines:
        if "# flow-harness-path" in line:
            skip_next = True
            continue
        if skip_next and line.startswith("PATH="):
            skip_next = False
            continue
        skip_next = False
        cleaned.append(line)
    return "\n".join(cleaned) + "\n" if cleaned else ""


def remove_flow_entries(crontab: str) -> str:
    lines = crontab.splitlines()
    cleaned = []
    skip_next = False
    for line in lines:
        if CRON_TAG in line:
            skip_next = True
            continue
        if skip_next:
            skip_next = False
            continue
        cleaned.append(line)
    return "\n".join(cleaned) + "\n" if cleaned else ""


def build_cron_entry(schedule: dict, project_dir: str) -> str:
    cron_expr = schedule["cron"]
    skill = schedule["skill"]
    name = schedule["name"]
    shell_cmd = build_shell_command(schedule, project_dir)

    return (
        f"{CRON_TAG}: {skill}/{name}\n"
        f"{cron_expr} {shell_cmd}"
    )


def install_crontab(enabled: list[dict], project_dir: str) -> None:
    """Write enabled schedules to crontab (Linux)."""
    CRON_STATE_DIR.mkdir(parents=True, exist_ok=True)

    current = get_current_crontab()
    cleaned = remove_flow_entries(current)
    cleaned = remove_flow_path(cleaned)

    path_dirs = collect_path_dirs()
    path_line = f"# flow-harness-path\nPATH={path_dirs}\n"

    entries = []
    for s in enabled:
        entries.append(build_cron_entry(s, project_dir))

    new_crontab = cleaned.rstrip("\n") + "\n\n" + path_line + "\n".join(entries) + "\n"
    write_crontab(new_crontab)

    for s in enabled:
        print(f"  {s['skill']}/{s['name']}: {s['cron']} — {s['description']}")


# ── Commands ──────────────────────────────────────────────────────────────

def cmd_list(args: argparse.Namespace) -> None:
    """List all declared schedules across installed skills."""
    manifests = find_all_schedules()
    state = load_state()

    if not manifests:
        print("No schedules found in any installed skill manifests.")
        print(f"Skills root: {SKILLS_ROOT}")
        return

    print(f"{'Source':<12} {'Name':<25} {'Cron':<20} {'Enabled':<10} Description")
    print("─" * 100)

    for s in manifests:
        enabled = is_enabled(state, s["skill"], s["name"]) or s["enabled"]
        marker = "✓" if enabled else " "
        source = s.get("source", f"skill:{s['skill']}")
        label = "project" if source == "project" else s["skill"]
        print(f"{label:<12} {s['name']:<25} {s['cron']:<20} {marker:<10} {s['description']}")


def cmd_enable(args: argparse.Namespace) -> None:
    state = load_state()
    key = get_schedule_key(args.skill, args.schedule_name)
    state.setdefault("schedules", {})[key] = state.get("schedules", {}).get(key, {})
    state["schedules"][key]["enabled"] = True
    save_state(state)
    print(f"Enabled: {key}")
    print("Run 'flow-cron install' to apply.")


def cmd_disable(args: argparse.Namespace) -> None:
    state = load_state()
    key = get_schedule_key(args.skill, args.schedule_name)
    state.setdefault("schedules", {})[key] = state.get("schedules", {}).get(key, {})
    state["schedules"][key]["enabled"] = False
    save_state(state)
    print(f"Disabled: {key}")
    print("Run 'flow-cron install' to apply.")


def cmd_run(args: argparse.Namespace) -> None:
    """Trigger a schedule immediately."""
    manifests = find_all_schedules()
    target = None
    for s in manifests:
        if s["skill"] == args.skill and s["name"] == args.schedule_name:
            target = s
            break

    if not target:
        print(f"Schedule not found: {args.skill}/{args.schedule_name}", file=sys.stderr)
        sys.exit(1)

    project_dir = detect_project_dir()
    shell_cmd = build_shell_command(target, project_dir)

    print(f"Running: {args.skill}/{args.schedule_name}")
    print(f"Command: {shell_cmd}")
    print(f"Working directory: {project_dir}")
    print()

    CRON_STATE_DIR.mkdir(parents=True, exist_ok=True)
    with open(LOG_PATH, "a") as log:
        log.write(f"\n[{datetime.now(timezone.utc).isoformat()}] Manual trigger: {args.skill}/{args.schedule_name}\n")

    # Execute using the same shell command that launchd/cron would use
    os.chdir(project_dir)
    result = subprocess.run(
        ["/bin/zsh", "-c", shell_cmd],
        cwd=project_dir,
    )
    sys.exit(result.returncode)


def cmd_install(args: argparse.Namespace) -> None:
    """Install enabled schedules using launchd (macOS) or crontab (Linux)."""
    manifests = find_all_schedules()
    state = load_state()
    project_dir = detect_project_dir()

    enabled = []
    for s in manifests:
        if is_enabled(state, s["skill"], s["name"]) or s["enabled"]:
            enabled.append(s)

    if not enabled:
        print("No enabled schedules to install.")
        return

    if IS_MACOS:
        # Remove old crontab entries if migrating from cron → launchd
        old_crontab = get_current_crontab()
        if CRON_TAG in old_crontab:
            cleaned = remove_flow_entries(old_crontab)
            cleaned = remove_flow_path(cleaned)
            write_crontab(cleaned)
            print("Migrated: removed old flow-harness crontab entries.\n")

        print(f"Installing {len(enabled)} schedule(s) via launchd:")
        install_launchd(enabled, project_dir)
        print()
        print("launchd jobs will fire even if your Mac was asleep at the scheduled time.")
    else:
        print(f"Installing {len(enabled)} schedule(s) via crontab:")
        install_crontab(enabled, project_dir)


def cmd_uninstall(args: argparse.Namespace) -> None:
    """Remove all flow-harness scheduled jobs."""
    if IS_MACOS:
        uninstall_launchd()

    # Always clean crontab too (handles migration leftovers)
    current = get_current_crontab()
    if CRON_TAG in current:
        cleaned = remove_flow_entries(current)
        cleaned = remove_flow_path(cleaned)
        write_crontab(cleaned)
        print("Removed flow-harness crontab entries.")


def cmd_status(args: argparse.Namespace) -> None:
    """Show active flow-harness scheduled jobs."""
    if IS_MACOS:
        status_launchd()
    else:
        current = get_current_crontab()
        lines = current.splitlines()
        flow_entries = []
        for i, line in enumerate(lines):
            if CRON_TAG in line:
                if i + 1 < len(lines):
                    flow_entries.append((line, lines[i + 1]))
        if not flow_entries:
            print("No flow-harness entries in crontab.")
            return
        print(f"Active cron entries ({len(flow_entries)}):\n")
        for tag, entry in flow_entries:
            label = tag.replace(CRON_TAG + ": ", "")
            print(f"  {label}")
            print(f"    {entry}")
            print()


# ── Main ──────────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        prog="flow-cron",
        description="Standardized scheduling for Harnessy skills",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("list", help="List all declared schedules")

    p_enable = sub.add_parser("enable", help="Enable a schedule")
    p_enable.add_argument("skill")
    p_enable.add_argument("schedule_name")

    p_disable = sub.add_parser("disable", help="Disable a schedule")
    p_disable.add_argument("skill")
    p_disable.add_argument("schedule_name")

    p_run = sub.add_parser("run", help="Trigger a schedule immediately")
    p_run.add_argument("skill")
    p_run.add_argument("schedule_name")

    sub.add_parser("install", help="Install schedules (launchd on macOS, crontab on Linux)")
    sub.add_parser("uninstall", help="Remove all flow-harness schedules")
    sub.add_parser("status", help="Show active schedules")

    args = parser.parse_args()

    commands = {
        "list": cmd_list,
        "enable": cmd_enable,
        "disable": cmd_disable,
        "run": cmd_run,
        "install": cmd_install,
        "uninstall": cmd_uninstall,
        "status": cmd_status,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
