#!/usr/bin/env python3
"""
collect-state — Scan all project state and produce JSON to stdout.

The "cheap detector": answers "did anything change?" not "what does it mean?"
Runs from project root (auto-detected via git or cwd).
"""

import argparse
import datetime
import hashlib
import json
import os
import re
import subprocess
import sys

# ── Paths ────────────────────────────────────────────────────────────────────

PROJECT_ROOT = os.environ.get(
    "FLOW_PROJECT_ROOT",
    os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(
        os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    ))))
)

_USERNAME = os.environ.get("FLOW_USER", os.environ.get("USER", "julian"))
PRIVATE_DIR = os.path.join(PROJECT_ROOT, ".jarvis", "context", "private", _USERNAME)
DOCS_DIR = os.path.join(PROJECT_ROOT, ".jarvis", "context", "docs")
GOAL_AGENT_DIR = os.path.join(PROJECT_ROOT, ".goal-agent")
AUTOFLOW_STATE = os.path.join(PROJECT_ROOT, ".jarvis", "context", "autoflow", "state.json")
CRON_YAML = os.path.join(PROJECT_ROOT, ".jarvis", "cron.yaml")
JARVIS_PLANS = os.path.expanduser("~/.jarvis/plans")
JARVIS_WIKIS = os.path.expanduser("~/.jarvis/wikis")
LAST_CRAWL = os.path.expanduser("~/.agents/life/.last-crawl.json")
NOTES_DIR = os.path.join(PRIVATE_DIR, "notes")


# ── Helpers ──────────────────────────────────────────────────────────────────

def read_file(path):
    """Read file contents, return None if missing."""
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            return f.read()
    except (OSError, IOError):
        return None


def read_json(path):
    """Read and parse a JSON file, return None if missing or invalid."""
    text = read_file(path)
    if text is None:
        return None
    try:
        return json.loads(text)
    except (json.JSONDecodeError, ValueError):
        return None


def run_cmd(args, cwd=None):
    """Run a command, return stdout or None on failure."""
    try:
        result = subprocess.run(
            args,
            capture_output=True, text=True, timeout=10,
            cwd=cwd or PROJECT_ROOT,
        )
        if result.returncode == 0:
            return result.stdout.strip()
        return None
    except (OSError, subprocess.TimeoutExpired):
        return None


def scan_dir(dirpath):
    """Walk a directory and return list of relative file paths + metadata."""
    files = []
    newest = 0.0
    if not os.path.isdir(dirpath):
        return files, newest
    for root, _dirs, filenames in os.walk(dirpath):
        for fname in filenames:
            if fname.startswith("."):
                continue
            full = os.path.join(root, fname)
            try:
                mtime = os.path.getmtime(full)
            except OSError:
                mtime = 0.0
            rel = os.path.relpath(full, dirpath)
            files.append({"path": rel, "modified": datetime.datetime.fromtimestamp(mtime, tz=datetime.timezone.utc).isoformat()})
            if mtime > newest:
                newest = mtime
    return files, newest


# ── Section collectors ───────────────────────────────────────────────────────

def collect_priorities():
    """Parse priorities.md — extract table rows, constraints, personal notes."""
    text = read_file(os.path.join(PRIVATE_DIR, "priorities.md"))
    if text is None:
        return None

    result = {"raw": text, "table": [], "constraints": [], "personal": [], "standing_instructions": []}

    # Extract markdown table rows (skip header + separator)
    in_table = False
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("| Project") or stripped.startswith("|---"):
            in_table = True
            continue
        if in_table and stripped.startswith("|"):
            cells = [c.strip() for c in stripped.strip("|").split("|")]
            if len(cells) >= 4:
                result["table"].append({
                    "project": cells[0],
                    "priority": cells[1],
                    "status": cells[2],
                    "next_milestone": cells[3],
                })
        elif in_table and not stripped.startswith("|"):
            in_table = False

    # Extract bullet sections by heading
    current_section = None
    for line in text.splitlines():
        heading_match = re.match(r"^##\s+(.+)", line)
        if heading_match:
            heading = heading_match.group(1).strip().lower()
            if "constraint" in heading:
                current_section = "constraints"
            elif "personal" in heading:
                current_section = "personal"
            elif "standing" in heading:
                current_section = "standing_instructions"
            else:
                current_section = None
            continue
        if current_section and line.strip().startswith("- "):
            result[current_section].append(line.strip()[2:])

    return result


def collect_projects():
    """Auto-discover project directories under the private context folder.

    Any subdirectory (not starting with . or _) is treated as a project.
    Description is pulled from status.md first line if present, else the dirname.
    No hardcoded project list — private context stays private.
    """
    projects = {}

    if os.path.isdir(PRIVATE_DIR):
        for entry in sorted(os.listdir(PRIVATE_DIR)):
            if entry.startswith((".","_")) or not os.path.isdir(os.path.join(PRIVATE_DIR, entry)):
                continue
            # Skip known non-project dirs
            if entry == "notes":
                continue

            dirpath = os.path.join(PRIVATE_DIR, entry)
            files, newest = scan_dir(dirpath)
            status_md = read_file(os.path.join(dirpath, "status.md"))

            # Extract description from status.md first heading, or use dirname
            description = entry
            if status_md:
                for line in status_md.splitlines():
                    if line.startswith("# "):
                        description = line[2:].strip()
                        break

            projects[entry] = {
                "description": description,
                "file_count": len(files),
                "newest_modified": datetime.datetime.fromtimestamp(newest, tz=datetime.timezone.utc).isoformat() if newest > 0 else None,
                "status_md": status_md,
                "files": files,
            }

    # Also include standalone files in private dir
    for fname in ("decisions.md", "events.md", "facts.md", "preferences.md"):
        content = read_file(os.path.join(PRIVATE_DIR, fname))
        if content is not None:
            projects[f"_private/{fname}"] = {"content": content}

    # Docs directory
    docs_files, docs_newest = scan_dir(DOCS_DIR)
    if docs_files:
        projects["_docs"] = {
            "file_count": len(docs_files),
            "newest_modified": datetime.datetime.fromtimestamp(docs_newest, tz=datetime.timezone.utc).isoformat() if docs_newest > 0 else None,
            "files": docs_files,
        }

    return projects


def collect_git():
    """Recent commits, current branch, uncommitted changes."""
    return {
        "branch": run_cmd(["git", "branch", "--show-current"]),
        "recent_commits": (run_cmd(["git", "log", "--since=7 days ago", "--oneline", "-n", "30"]) or "").splitlines(),
        "uncommitted": (run_cmd(["git", "status", "--short"]) or "").splitlines(),
    }


def collect_agents():
    """Goal-agent run states from .goal-agent/*/state.json."""
    agents = {}
    if not os.path.isdir(GOAL_AGENT_DIR):
        return agents
    try:
        for entry in os.listdir(GOAL_AGENT_DIR):
            state_path = os.path.join(GOAL_AGENT_DIR, entry, "state.json")
            state = read_json(state_path)
            if state is not None:
                agents[entry] = state
    except OSError:
        pass

    # Autoflow state
    autoflow = read_json(AUTOFLOW_STATE)
    if autoflow is not None:
        agents["_autoflow"] = autoflow

    return agents


def collect_tmux():
    """Active tmux sessions."""
    output = run_cmd(["tmux", "list-sessions"])
    if output is None:
        return []
    return output.splitlines()


def collect_cron():
    """Contents of .jarvis/cron.yaml."""
    return read_file(CRON_YAML)


def collect_notes():
    """Read recent daily notes (today + yesterday) from private/notes/."""
    today = datetime.date.today()
    yesterday = today - datetime.timedelta(days=1)
    notes = {}

    for day in (today, yesterday):
        year = day.strftime("%Y")
        month = day.strftime("%b")
        dd = day.strftime("%d")
        path = os.path.join(NOTES_DIR, year, month, f"{dd}.md")
        content = read_file(path)
        if content is not None:
            notes[day.isoformat()] = content

    return notes if notes else None


def collect_wiki_updates():
    """Scan ~/.jarvis/wikis/*/ for recent autonomous-research activity.

    Reads each domain's `wiki/log.md` for entries in the last 24 hours, the
    most recent findings files in `.state/findings/`, and the pending seed
    queue. The morning brief surfaces this so Julian sees what his research
    agents found overnight.
    """
    if not os.path.isdir(JARVIS_WIKIS):
        return None

    cutoff = datetime.datetime.now() - datetime.timedelta(hours=24)
    log_ts_re = re.compile(r"^\[(\d{4}-\d{2}-\d{2}) (\d{2}):(\d{2})\]")
    domains = {}
    total_pending = 0
    total_recent_sessions = 0

    for entry in sorted(os.listdir(JARVIS_WIKIS)):
        domain_root = os.path.join(JARVIS_WIKIS, entry)
        if not os.path.isdir(domain_root):
            continue
        wiki_dir = os.path.join(domain_root, "wiki")
        if not os.path.isdir(wiki_dir):
            continue

        # Title from schema.yaml (best-effort, no yaml dep available here)
        title = entry
        schema_text = read_file(os.path.join(domain_root, "schema.yaml")) or ""
        for line in schema_text.splitlines():
            line = line.strip()
            if line.startswith("title:"):
                title = line.split(":", 1)[1].strip().strip("'\"")
                break

        # Recent log entries (within last 24h)
        log_text = read_file(os.path.join(wiki_dir, "log.md")) or ""
        recent_entries = []
        for line in log_text.splitlines():
            m = log_ts_re.match(line.strip())
            if not m:
                continue
            try:
                entry_dt = datetime.datetime.strptime(
                    f"{m.group(1)} {m.group(2)}:{m.group(3)}",
                    "%Y-%m-%d %H:%M",
                )
            except ValueError:
                continue
            if entry_dt >= cutoff:
                recent_entries.append(line.strip())

        # Recent findings files (read frontmatter for structured fields)
        findings_dir = os.path.join(domain_root, ".state", "findings")
        recent_findings = []
        if os.path.isdir(findings_dir):
            files = sorted(
                (f for f in os.listdir(findings_dir) if f.endswith(".md")),
                reverse=True,
            )[:5]
            for f in files:
                fp = os.path.join(findings_dir, f)
                if os.path.getmtime(fp) < cutoff.timestamp():
                    continue
                fm = _parse_simple_frontmatter(read_file(fp) or "")
                recent_findings.append(
                    {
                        "file": f,
                        "session_id": fm.get("session_id"),
                        "topic": fm.get("topic"),
                        "files_created": fm.get("files_created"),
                        "errors": fm.get("errors"),
                    }
                )
                total_recent_sessions += 1

        # Pending seed count from seeds.md
        pending_count = _count_pending_seeds(
            read_file(os.path.join(domain_root, "seeds.md")) or ""
        )
        total_pending += pending_count

        # Active topics from program.md (just the bullet names, best-effort)
        active_topics = _extract_active_topics(
            read_file(os.path.join(domain_root, "program.md")) or ""
        )

        # Skip domains with nothing to report
        if not recent_entries and not recent_findings and pending_count == 0:
            continue

        domains[entry] = {
            "title": title,
            "pending_seeds": pending_count,
            "recent_log_entries": recent_entries[-10:],  # most recent 10
            "recent_findings": recent_findings,
            "active_topics": active_topics,
        }

    if not domains:
        return None
    return {
        "domains": domains,
        "total_pending_seeds": total_pending,
        "total_recent_sessions": total_recent_sessions,
    }


def _parse_simple_frontmatter(text):
    """Parse top YAML frontmatter as a flat dict (no yaml dep)."""
    if not text.startswith("---"):
        return {}
    end = text.find("\n---", 3)
    if end == -1:
        return {}
    block = text[3:end]
    out = {}
    for line in block.splitlines():
        if ":" in line:
            k, _, v = line.partition(":")
            out[k.strip()] = v.strip()
    return out


def _count_pending_seeds(text):
    """Count `### ` headings inside the `## Pending` section of a seeds.md file."""
    if "## Pending" not in text:
        return 0
    pending_start = text.find("## Pending")
    processed_start = text.find("## Processed", pending_start)
    section = text[pending_start:processed_start] if processed_start != -1 else text[pending_start:]
    return sum(1 for line in section.splitlines() if line.startswith("### "))


def _extract_active_topics(text):
    """Extract bullet names from the `## Active Topics` section of program.md."""
    if "## Active Topics" not in text:
        return []
    start = text.find("## Active Topics")
    # Find the next H2 header
    next_h2 = text.find("\n## ", start + 4)
    section = text[start:next_h2] if next_h2 != -1 else text[start:]
    # Strip HTML comments
    section = re.sub(r"<!--.*?-->", "", section, flags=re.DOTALL)
    topics = []
    for line in section.splitlines():
        stripped = line.strip()
        if stripped.startswith(("- ", "* ")):
            # Take everything before the first " —" or " -" qualifier
            name = re.split(r"\s+[—-]\s+", stripped[2:].strip(), maxsplit=1)[0]
            if name:
                topics.append(name.strip())
    return topics[:10]


def collect_jarvis_plans():
    """Find latest plan from ~/.jarvis/plans/."""
    if not os.path.isdir(JARVIS_PLANS):
        return None
    try:
        md_files = [
            f for f in os.listdir(JARVIS_PLANS)
            if f.endswith(".md") and not f.startswith(".")
        ]
        if not md_files:
            return None
        # Sort by mtime, newest first
        md_files.sort(
            key=lambda f: os.path.getmtime(os.path.join(JARVIS_PLANS, f)),
            reverse=True,
        )
        latest = md_files[0]
        content = read_file(os.path.join(JARVIS_PLANS, latest))
        return {"file": latest, "content": content}
    except OSError:
        return None


# ── Change detection ─────────────────────────────────────────────────────────

def compute_hash(state):
    """Hash the state dict (excluding volatile fields) for change detection."""
    hashable = {k: v for k, v in state.items() if k not in ("changed", "timestamp")}
    raw = json.dumps(hashable, sort_keys=True, default=str)
    return hashlib.sha256(raw.encode()).hexdigest()


def check_changed(current_hash):
    """Compare against last crawl. Returns True if changed or no prior crawl."""
    last = read_json(LAST_CRAWL)
    if last is None:
        return True
    return last.get("hash") != current_hash


def save_crawl(current_hash):
    """Persist current hash for next comparison."""
    crawl_dir = os.path.dirname(LAST_CRAWL)
    try:
        os.makedirs(crawl_dir, exist_ok=True)
        with open(LAST_CRAWL, "w") as f:
            json.dump({
                "hash": current_hash,
                "timestamp": datetime.datetime.now(tz=datetime.timezone.utc).isoformat(),
            }, f)
    except OSError as e:
        print(f"Warning: could not save crawl state: {e}", file=sys.stderr)


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Collect state across all projects — answers 'did anything change?'"
    )
    parser.add_argument(
        "--no-save", action="store_true",
        help="Don't update .last-crawl.json (dry run)"
    )
    args = parser.parse_args()

    state = {
        "priorities": collect_priorities(),
        "projects": collect_projects(),
        "notes": collect_notes(),
        "git": collect_git(),
        "agents": collect_agents(),
        "tmux_sessions": collect_tmux(),
        "cron": collect_cron(),
        "jarvis": collect_jarvis_plans(),
        "wiki_updates": collect_wiki_updates(),
        "timestamp": datetime.datetime.now(tz=datetime.timezone.utc).isoformat(),
    }

    current_hash = compute_hash(state)
    state["changed"] = check_changed(current_hash)

    json.dump(state, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")

    if not args.no_save:
        save_crawl(current_hash)


if __name__ == "__main__":
    main()
